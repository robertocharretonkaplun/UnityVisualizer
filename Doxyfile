# =============================================================================
#  Doxyfile — Unity HDRP Product Visualizer
#  Run:  doxygen Doxyfile
#  Output: docs/html/index.html  (served via GitHub Pages)
# =============================================================================

# ---------------------------------------------------------------------------
# Project identity
# ---------------------------------------------------------------------------
PROJECT_NAME           = "Unity HDRP Product Visualizer"
PROJECT_BRIEF          = "Interactive 3D product showcase built with Unity 6 and HDRP"
PROJECT_NUMBER         = "1.0.0"
PROJECT_LOGO           =

OUTPUT_DIRECTORY       = docs
# HTML goes into docs/html — the workflow uploads only that subfolder to gh-pages

# ---------------------------------------------------------------------------
# Input
# ---------------------------------------------------------------------------
INPUT                  = UnityVisualizer/Assets/ProductVisualizer \
                         README.md
FILE_PATTERNS          = *.cs *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */Generated/* \
                         */obj/* \
                         */Library/* \
                         *.meta

# Parse the Shaders folder for the HLSL background shader documentation
INPUT                 += UnityVisualizer/Assets/ProductVisualizer/Shaders
FILE_PATTERNS         += *.shader

# Use README.md as the main page
USE_MDFILE_AS_MAINPAGE = README.md

# ---------------------------------------------------------------------------
# Extraction
# ---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES

HIDE_UNDOC_RELATIONS   = NO
INLINE_INHERITED_MEMB  = YES
INHERIT_DOCS           = YES

# ---------------------------------------------------------------------------
# Source code browsing
# ---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# ---------------------------------------------------------------------------
# Optimisation for C# / Java-style code
# ---------------------------------------------------------------------------
OPTIMIZE_OUTPUT_JAVA   = YES
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO

# ---------------------------------------------------------------------------
# HTML output
# ---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html

# Modern built-in theme
HTML_COLORSTYLE        = LIGHT
HTML_COLORSTYLE_HUE    = 220
HTML_COLORSTYLE_SAT    = 80
HTML_COLORSTYLE_GAMMA  = 100

GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 260
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO

# Collapse namespaces in the sidebar by default
ENUM_VALUES_PER_LINE   = 1

# ---------------------------------------------------------------------------
# Diagrams (requires Graphviz dot; disable if not installed on CI)
# ---------------------------------------------------------------------------
HAVE_DOT               = YES
DOT_NUM_THREADS        = 0
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_TRANSPARENT        = YES

# ---------------------------------------------------------------------------
# Disable unused generators
# ---------------------------------------------------------------------------
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO
GENERATE_DOCBOOK       = NO

# ---------------------------------------------------------------------------
# Warnings
# ---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
