# =============================================================================
#  Doxyfile — Unity HDRP Product Visualizer
#  Run:  doxygen Doxyfile
#  Output: docs/html/index.html  (served via GitHub Pages)
# =============================================================================

# ---------------------------------------------------------------------------
# Project identity
# ---------------------------------------------------------------------------
PROJECT_NAME           = "Unity HDRP Product Visualizer"
PROJECT_BRIEF          = "Interactive 3D product showcase built with Unity 6 and HDRP"
PROJECT_NUMBER         = "1.0.0"
PROJECT_LOGO           =

OUTPUT_DIRECTORY       = docs

# ---------------------------------------------------------------------------
# Input  —  all paths relative to repo root (where doxygen is invoked)
# ---------------------------------------------------------------------------
INPUT                  = UnityVisualizer/Assets/ProductVisualizer/Scripts \
                         UnityVisualizer/Assets/ProductVisualizer/Editor \
                         UnityVisualizer/Assets/ProductVisualizer/Shaders \
                         README.md

FILE_PATTERNS          = *.cs *.shader *.md

RECURSIVE              = NO

EXCLUDE_PATTERNS       = */Generated/* \
                         *.meta

USE_MDFILE_AS_MAINPAGE = README.md

# ---------------------------------------------------------------------------
# Extraction
# ---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
INLINE_INHERITED_MEMB  = YES
INHERIT_DOCS           = YES

# ---------------------------------------------------------------------------
# Source browsing
# ---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# ---------------------------------------------------------------------------
# C# / Java-style optimisation
# ---------------------------------------------------------------------------
OPTIMIZE_OUTPUT_JAVA   = YES
JAVADOC_AUTOBRIEF      = YES

# ---------------------------------------------------------------------------
# HTML output
# ---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html

HTML_COLORSTYLE        = LIGHT
HTML_COLORSTYLE_HUE    = 220
HTML_COLORSTYLE_SAT    = 80
HTML_COLORSTYLE_GAMMA  = 100

GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 260
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
SEARCHENGINE           = YES

ENUM_VALUES_PER_LINE   = 1

# ---------------------------------------------------------------------------
# Diagrams — use PNG to avoid SVG rendering issues on Pages
# ---------------------------------------------------------------------------
HAVE_DOT               = YES
DOT_NUM_THREADS        = 2
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
DOT_IMAGE_FORMAT       = png
INTERACTIVE_SVG        = NO
DOT_TRANSPARENT        = YES

# ---------------------------------------------------------------------------
# Disable unused generators
# ---------------------------------------------------------------------------
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO
GENERATE_DOCBOOK       = NO

# ---------------------------------------------------------------------------
# Warnings
# ---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
